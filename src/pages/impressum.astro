---
import Navigation from '../components/Navigation.astro';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Impressum — KUEPER.COM</title>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/kue-document.css">
  <style>
    body {
      background: var(--kue-bg, #f5f3ef);
      margin: 0;
      padding: 0;
    }
    .page-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem 2rem;
    }
    .page-title {
      font-size: 2rem;
      font-weight: 600;
      margin: 0 0 2rem 0;
      color: #1a1a1a;
    }
    .legal-section {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      margin-bottom: 2rem;
    }
    .legal-section h2 {
      font-size: 1.3rem;
      font-weight: 600;
      margin: 0 0 1rem 0;
      color: #1a1a1a;
    }
    .legal-section h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 1.5rem 0 0.75rem 0;
      color: #1a1a1a;
    }
    .legal-section p {
      line-height: 1.7;
      margin-bottom: 0.75rem;
      color: #333;
    }
    .legal-section p:last-child {
      margin-bottom: 0;
    }
    .legal-section a {
      color: #1a1a1a;
    }
    .ip-list {
      margin: 0.5rem 0 0.75rem 1.5rem;
      line-height: 1.8;
      color: #333;
    }
  </style>
</head>
<body>
  <Navigation />

  <div class="page-container">
    <h1 class="page-title">Impressum</h1>

    <div class="legal-section">
