---
import Navigation from '../components/Navigation.astro';
import legal from '../generated/legal.json';

const { responsible, documentId, registryStatus, status, updated } = legal.imprint;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Impressum — KUEPER.COM</title>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/kue-document.css">
  <style>
    body { background: var(--kue-bg, #f5f3ef); margin: 0; }
    .page-container { max-width: 800px; margin: 0 auto; padding: 3rem 2rem 6rem; }
    .page-title { font-size: 2rem; font-weight: 600; margin: 0 0 .5rem; color: #1a1a1a; }
    .meta { color: #666; font-family: 'JetBrains Mono', monospace; font-size: .78rem; margin-bottom: 2rem; }
    .legal-section { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.06); margin-bottom: 2rem; }
    .legal-section h2 { font-size: 1.3rem; margin-top: 0; }
    .legal-section p { line-height: 1.7; color: #333; }
    .legal-section a { color: #1a1a1a; }
  </style>
</head>
<body>
  <Navigation />
  <main class="page-container">
    <h1 class="page-title">Impressum</h1>
    <div class="meta">{documentId} · Registry: {registryStatus} · Quelle: {status} · Stand: {updated}</div>

    <section class="legal-section">
      <h2>Angaben zum Verantwortlichen</h2>
      <p>
        {responsible.name}<br />
        {responsible.address}
      </p>
      <p>E-Mail: <a href={`mailto:${responsible.email}`}>{responsible.email}</a></p>
    </section>

    <section class="legal-section">
      <h2>Verantwortlich für den Inhalt</h2>
      <p>{responsible.name}<br />{responsible.address}</p>
    </section>

    <section class="legal-section">
      <h2>Quellenhinweis</h2>
      <p>Die Verantwortlichen-Daten werden beim Build aus der zentralen Rechtsdaten-Registry des KUEPER Knowledge Graph übernommen und in diesem Repository nicht als eigenständige rechtliche Systemwahrheit gepflegt.</p>
    </section>
  </main>
</body>
</html>
