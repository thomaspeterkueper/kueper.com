---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => path === '/' ? currentPath === '/' : currentPath.startsWith(path);
---

<nav class="main-nav">
  <div class="nav-container">
    <a href="/" class="nav-brand" aria-label="KUEPER.COM Startseite">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="8" y="8" width="8" height="8" transform="rotate(45 12 12)" stroke="currentColor" stroke-width="1.5" />
        <circle cx="12" cy="12" r="1.5" fill="currentColor" />
      </svg>
      <span class="nav-title">KUEPER.COM</span>
    </a>

    <div class="nav-menu">
      <a href="/" class={isActive('/') ? 'nav-link active' : 'nav-link'}>Start</a>
      <a href="/kue" class={isActive('/kue') ? 'nav-link active' : 'nav-link'}>Archiv</a>
      <a href="/ueber" class={isActive('/ueber') ? 'nav-link active' : 'nav-link'}>Über das Archiv</a>
      <a href="/dokumentenklassen" class={isActive('/dokumentenklassen') ? 'nav-link active' : 'nav-link'}>Dokumentenklassen</a>
    </div>

    <div class="nav-lang" aria-label="Sprachauswahl">
      <span class="lang-active">DE</span><span>/</span><span class="lang-disabled">EN</span>
    </div>
  </div>
</nav>

<footer class="site-footer">
  <span class="footer-copy">© {new Date().getFullYear()} Thomas Peter Küper</span>
  <div class="footer-links">
    <a href="/impressum">Impressum</a>
    <a href="/datenschutz">Datenschutz</a>
    <a href="/nutzungsbedingungen">Nutzungsbedingungen</a>
  </div>
</footer>

<style>
  .main-nav { position: sticky; top: 0; z-index: 1000; background: rgba(255,255,255,.98); backdrop-filter: blur(12px); border-bottom: 1px solid #e0e0e0; box-shadow: 0 2px 8px rgba(0,0,0,.04); }
  .nav-container { max-width: 1400px; margin: 0 auto; padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .nav-brand { display: flex; align-items: center; gap: .75rem; text-decoration: none; color: #1a1a1a; font-weight: 600; font-size: .95rem; letter-spacing: .03em; }
  .nav-title, .nav-lang, .footer-copy { font-family: 'JetBrains Mono', monospace; }
  .nav-menu { display: flex; align-items: center; gap: .5rem; flex: 1; justify-content: center; }
  .nav-link { padding: .5rem 1rem; text-decoration: none; color: #4a4a4a; font-size: .9rem; font-weight: 500; border-radius: 6px; }
  .nav-link:hover, .nav-link.active { color: #1a1a1a; background: #f0f0f0; }
  .nav-lang { display: flex; gap: .35rem; font-size: .85rem; color: #666; }
  .lang-active { font-weight: 600; color: #1a1a1a; }
  .lang-disabled { opacity: .4; }
  .site-footer { margin: 6rem auto 0; padding: 2rem; border-top: 1px solid #e0e0e0; display: flex; justify-content: space-between; align-items: center; gap: 1rem; max-width: 1400px; }
  .footer-copy, .footer-links a { font-size: .85rem; color: #888; }
  .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .footer-links a { text-decoration: none; }
  .footer-links a:hover { color: #1a1a1a; }
  @media (max-width: 768px) { .nav-container { padding: 0 1rem; } .nav-menu { display: none; } .nav-title { display: none; } }
  @media (max-width: 600px) { .site-footer { flex-direction: column; align-items: flex-start; padding: 1.5rem 1rem; } }
</style>
